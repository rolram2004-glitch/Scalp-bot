{
  "name": "scalp-bot",
  "version": "1.0.0",
  "description": "Forex Scalping Bot",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend",
    "postinstall": "npm --prefix frontend install && npm --prefix frontend run build",
    "test": "node --test"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": "22.x"
  }
}
